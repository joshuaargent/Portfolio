# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Joshua Argent
NEXT_PUBLIC_SITE_DESCRIPTION=I run 5km a day, read a lot, and share what I learn about fitness and faith.

# Strava Integration
# 1. Create an application at https://www.strava.com/settings/api
# 2. Get your Client ID and Client Secret
# 3. Authorize your account to get an access token: https://www.strava.com/oauth/authorize?client_id=YOUR_CLIENT_ID&response_type=code&redirect_uri=http://localhost
# 4. Exchange the code for a token: curl -X POST https://www.strava.com/oauth/token -d "client_id=YOUR_CLIENT_ID&client_secret=YOUR_CLIENT_SECRET&code=YOUR_CODE&grant_type=authorization_code"
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# Newsletter (Buttondown)
# Get your API key from https://buttondown.com/settings/api
BUTTONDOWN_API_KEY=

# Contact Form (Formspree)
# Create a form at https://formspree.io/forms/{your-form-id}/embed
NEXT_PUBLIC_FORMSPREE_FORM_ID=