# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Integration (for code page)
# Required for repo data - Get token at https://github.com/settings/tokens
GITHUB_USERNAME=joshuaargent
GITHUB_TOKEN=

# YouTube Integration (for videos + subscriber counts)
# Required - Get from https://console.cloud.google.com/ (Enable YouTube Data API v3)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Strava Integration (for running data)
# Required - Get from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# Newsletter (Buttondown)
# Optional - Get from https://buttondown.com/settings/api
BUTTONDOWN_API_KEY=

# Contact Form (Formspree)
# Optional - Get from https://formspree.io/
NEXT_PUBLIC_FORMSPREE_FORM_ID=